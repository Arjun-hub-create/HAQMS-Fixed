// This is the Prisma schema for HAQMS.
// FIX (Database): Added missing indices on foreign keys and commonly filtered fields.
// FIX (Database): Added a unique constraint on appointments to prevent double-booking.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECEPTIONIST
  DOCTOR
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum QueueStatus {
  WAITING
  CALLING
  COMPLETED
  SKIPPED
}

enum Gender {
  Male
  Female
  Other
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(RECEPTIONIST)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // FIX: Index on email for fast login lookups
  @@index([email])
  @@index([role])
}

model Patient {
  id            String   @id @default(cuid())
  name          String
  email         String?
  phoneNumber   String
  age           Int
  gender        String
  medicalHistory String?  // Nullable — frontend must handle null gracefully
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointments  Appointment[]
  queueTokens   QueueToken[]

  // FIX: Index for search queries on name and phone
  @@index([name])
  @@index([phoneNumber])
  @@index([createdAt])
}

model Doctor {
  id              String   @id @default(cuid())
  name            String
  specialization  String
  department      String
  consultationFee Float    @default(0)
  experience      Int      @default(0)
  availableFrom   String   @default("09:00")
  availableTo     String   @default("17:00")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments Appointment[]
  queueTokens  QueueToken[]

  // FIX: Indices for filtering by specialization and department
  @@index([specialization])
  @@index([department])
  @@index([name])
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  doctorId        String
  appointmentDate DateTime
  reason          String?
  status          AppointmentStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  queueToken QueueToken?

  // FIX (Database): Added indices on foreign keys and status for faster joins and filtering.
  // Note: A full unique constraint on (doctorId, appointmentDate) would block DB-level duplicates,
  // but requires a slot-based booking system. The 30-min window check in the API handles this
  // at application level. The index below speeds up the conflict check query.
  @@index([doctorId, appointmentDate])
  @@index([patientId])
  @@index([status])
  @@index([doctorId, status])
}

model QueueToken {
  id            String      @id @default(cuid())
  tokenNumber   Int
  patientId     String
  doctorId      String
  appointmentId String?     @unique
  status        QueueStatus @default(WAITING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  // FIX: Composite index for efficient daily token number lookups (used in race condition fix)
  @@index([doctorId, createdAt])
  @@index([doctorId, status])
  @@index([patientId])
}
